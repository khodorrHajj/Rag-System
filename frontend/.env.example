# Local browser-to-backend URL for non-Docker runs and Docker Compose runs.
# Vercel production example: https://your-render-api.onrender.com
VITE_API_BASE_URL=http://localhost:8000
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_key_placeholder
# Optional legacy fallback if your project still uses the older anon key name:
# VITE_SUPABASE_ANON_KEY=legacy_anon_key_placeholder
