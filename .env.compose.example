# Docker Compose variable substitution only.
# Backend secrets stay in backend/.env.

BACKEND_PORT=8000
FRONTEND_PORT=4173
POSTGRES_PORT=5432
REDIS_PORT=6379

POSTGRES_DB=rag_document_assistant
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

DOCKER_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/rag_document_assistant?sslmode=disable
DOCKER_REDIS_URL=redis://redis:6379/0
DOCKER_FRONTEND_ORIGIN=http://localhost:4173
DOCKER_ENVIRONMENT=development
DOCKER_STORAGE_BACKEND=local

VITE_API_BASE_URL=http://localhost:8000
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_key_placeholder
# Optional legacy fallback if your project still uses the older anon key name:
# VITE_SUPABASE_ANON_KEY=legacy_anon_key_placeholder
