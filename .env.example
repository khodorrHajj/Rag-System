# Backend environment variables only.
# Do not place backend secrets in the frontend.

ENVIRONMENT=development
FRONTEND_ORIGIN=http://localhost:5173

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rag_document_assistant?sslmode=prefer
DATABASE_POOL_ENABLED=true
DATABASE_POOL_MIN_SIZE=1
DATABASE_POOL_MAX_SIZE=5
DATABASE_POOL_TIMEOUT_SECONDS=10
WARM_DATABASE_POOL_ON_STARTUP=true
REDIS_URL=redis://localhost:6379/0

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_JWKS_URL=https://your-project-id.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ISSUER=https://your-project-id.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_SECRET=
SUPABASE_ANON_KEY=sb_publishable_key_placeholder
SUPABASE_SERVICE_ROLE_KEY=sb_service_role_key_placeholder
AUTH_ALLOW_UNVERIFIED_JWT=false

OPENROUTER_API_KEY=sk-or-placeholder
OPENROUTER_MODEL_PRIMARY=nvidia/nemotron-3-ultra-550b-a55b
OPENROUTER_MODEL_FALLBACK=nex-agi/nex-n2-pro
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
LLM_TIMEOUT_SECONDS=45
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=700
MAX_CONTEXT_CHARS=16000
MAX_QUESTION_CHARS=2000
MAX_CHAT_HISTORY_MESSAGES=8
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=32
EMBEDDING_NORMALIZE=true
WARM_EMBEDDING_MODEL_ON_STARTUP=true
VECTOR_SEARCH_WEIGHT=0.7
KEYWORD_SEARCH_WEIGHT=0.3
RETRIEVAL_TOP_K=5
RETRIEVAL_CANDIDATE_K=20
RETRIEVAL_SCORE_THRESHOLD=0.45
MAX_RETRIEVAL_QUERY_CHARS=1000

STORAGE_BUCKET_NAME=rag-document
STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=./storage/private
STORAGE_SIGNED_URL_SECRET=development-storage-signing-secret

MAX_UPLOAD_SIZE_MB=20
ALLOWED_UPLOAD_EXTENSIONS=pdf
DOCUMENT_QUEUE_NAME=queue:index_documents
INDEXING_MAX_ATTEMPTS=3
INDEXING_QUEUE_BLOCK_TIMEOUT_SECONDS=5
PARSED_ARTIFACT_PREFIX=artifacts/parsed
CHUNK_ARTIFACT_PREFIX=artifacts/chunks
CHUNK_MAX_CHARS=1200
CHUNK_OVERLAP_CHARS=200
CHUNK_MIN_CHARS=100
MAX_CHUNKS_PER_DOCUMENT=500
ENABLE_SEMANTIC_CHUNKING=false

TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_IPS=127.0.0.1,::1
