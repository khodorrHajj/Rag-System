ENVIRONMENT=development
FRONTEND_ORIGIN=http://localhost:4173
ADMIN_EMAILS=dev@example.com

# Local Docker/Postgres example:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rag_document_assistant?sslmode=disable
# Hosted Supabase example:
# DATABASE_URL=postgresql://postgres:your_password@db.your-project-ref.supabase.co:5432/postgres
DATABASE_POOL_ENABLED=true
DATABASE_POOL_MIN_SIZE=1
DATABASE_POOL_MAX_SIZE=5
DATABASE_POOL_TIMEOUT_SECONDS=10
WARM_DATABASE_POOL_ON_STARTUP=true
REDIS_URL=redis://localhost:6379/0
# Hosted Upstash example:
# REDIS_URL=rediss://default:your-password@your-endpoint.upstash.io:6379

# Supabase project settings
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ISSUER=https://your-project-ref.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated

# Prefer modern key names when available
SUPABASE_PUBLISHABLE_KEY=sb_publishable_key_placeholder
SUPABASE_SECRET_KEY=sb_secret_key_placeholder

# Optional legacy fallback names if your project still relies on them
# SUPABASE_ANON_KEY=legacy_anon_key_placeholder
# SUPABASE_SERVICE_ROLE_KEY=legacy_service_role_key_placeholder

# Private object storage bucket for uploaded documents
STORAGE_BUCKET_NAME=rag-document
# Local dev: local
# Hosted Render + Supabase: supabase
STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=./storage/private

# Developer observability and lightweight evals
FEEDBACK_COMMENT_MAX_LENGTH=500
OBSERVABILITY_RECENT_LIMIT=20
EVAL_RESULTS_LIMIT=20
EVAL_ANSWER_PREVIEW_CHARS=240
EVAL_CASES_DIR=backend/evals
